<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>공지 작성</title>
    <link rel="stylesheet" href="/noticeWrite.css">


</head>
<body>

<div class="container">

    <h1>📢 공지 작성</h1>

    <form action="/notice/write" method="POST">

        <input
            type="text"
            name="title"
            placeholder="제목 입력"
            required
        >

        <textarea
            name="content"
            rows="10"
            placeholder="내용 입력"
            required
        ></textarea>

        <button type="submit">
            작성 완료
        </button>

    </form>

</div>

</body>
</html>