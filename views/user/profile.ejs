<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>프로필</title>

    <link rel="stylesheet" href="/myPage.css">
</head>
<body>

<%
    const profileImage = user?.profile_image || '/uploads/default-profile.png';

    const email = user?.email || '';

    const nickName = user?.nickName || '';

    const createdAt = user?.created_at
        ? new Date(user.created_at).toLocaleString('ko-KR')
        : '가입일 없음';
%>

<div class="container">

    <div class="mypage-card">

        <h1>👤 프로필</h1>

        <!-- 프로필 사진 변경 -->
        <form 
            action="/profile/update" 
            method="POST" 
            enctype="multipart/form-data"
            class="profile-form"
        >

            <div class="profile-image-box">

                <img 
                    src="<%= profileImage %>" 
                    alt="프로필"
                    class="profile-image"
                >

            </div>

            <input 
                type="file" 
                name="profile"
                class="file-input"
                accept="image/*"
            >

            <button type="submit" class="profile-btn">
                프로필 사진 변경
            </button>

        </form>

        <!-- 회원정보 수정 -->
        <form 
            action="/profile/user/update"
            method="POST"
            class="edit-form"
        >

            <div class="input-group">
                <label>이메일</label>

                <input 
                    type="email"
                    name="email"
                    value="<%= email %>"
                    readonly
                >
            </div>

            <div class="input-group">
                <label>닉네임</label>

                <input 
                    type="text"
                    name="nickName"
                    value="<%= nickName %>"
                    required
                >
            </div>

            <div class="input-group">
                <label>가입일</label>

                <input 
                    type="text"
                    value="<%= createdAt %>"
                    readonly
                >
            </div>

            <button type="submit" class="save-btn">
                회원정보 수정
            </button>

        </form>

        <!-- 버튼 -->
        <div class="btn-group">

            <a href="/" class="home-btn">
                홈으로
            </a>

            <a href="/logout" class="logout-btn">
                로그아웃
            </a>

        </div>

    </div>

</div>

</body>
</html>