<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>공부 기록</title>

    <link rel="stylesheet" href="/study.css">
</head>
<body>

<div class="container">

    <!-- 상단 -->
    <div class="header">
        <h2>📘 공부 기록 게시판</h2>

        <a href="/" class="home-btn">
            ← 메인으로
        </a>
    </div>

    <!-- 작성 버튼 -->
    <div class="write-btn-box">

        <a href="/study/write" class="write-btn">
            ✏ 글 작성
        </a>

    </div>

    <hr>

    <!-- 목록 -->
    <div class="list">

        <% if (logs.length === 0) { %>

            <p class="empty">
                작성된 기록이 없습니다.
            </p>

        <% } %>

        <% logs.forEach(log => { %>

            <div class="log-box">

                <!-- 상단 -->
                <div class="top">

                    <!-- 제목 클릭 시 TODO 이동 -->
                    <h3>

                    <% if (
                        session.user &&
                        (
                            session.user.user_id === log.user_id ||
                            session.user.role === 'admin'
                        )
                    ) { %>

                        <!-- 본인 또는 관리자 -->
                        <a href="/todo/<%= log.study_log_id %>"
                        class="title-link">

                            <%= log.title %>

                        </a>

                    <% } else { %>

                        <!-- 다른 사람 -->
                        <span class="locked-title">
                              <%= log.title %>
                        </span>

                    <% } %>

                    </h3>

                    <!-- 작성자 -->
                    <span class="writer">
                        👤 <%= log.nickName %>
                    </span>

                </div>

                <!-- 내용 -->
                <p class="content">
                    <%= log.content %>
                </p>

                <!-- 하단 -->
                <div class="bottom">

                    <span class="category">
                        📂 <%= log.category %>
                    </span>

                    <span class="time">
                        ⏱ <%= log.study_time %>시간
                    </span>

                    <!-- 날짜 -->
                    <span class="date">

                        <%
                            const time =
                                (log.updated_at &&
                                 log.updated_at != log.created_at)

                                ? log.updated_at
                                : log.created_at;
                        %>

                        <%= new Date(time).toLocaleString() %>

                    </span>

                    <!-- 수정 삭제 -->
                    <% if (
                        session.user &&
                        (
                            session.user.user_id === log.user_id ||
                            session.user.role === 'admin'
                        )
                    ) { %>

                        <!-- 수정 -->
                        <% if (
                            session.user.user_id === log.user_id
                        ) { %>

                            <a href="/study/edit/<%= log.study_log_id %>">
                                수정
                            </a>

                        <% } %>

                        <!-- 삭제 -->
                        <a href="/study/delete/<%= log.study_log_id %>"
                           onclick="return confirm('삭제할까요?')">

                            삭제

                        </a>

                    <% } %>

                </div>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>